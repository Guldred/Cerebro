{
  "name": "cerebro",
  "version": "0.1.0",
  "description": "Cerebro — a central, permission-aware, vectorized knowledge layer over heterogeneous enterprise sources (Confluence, GitLab, MS Teams). RAG with cited source links, exposed as a REST API and an MCP server.",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "mcp": "ts-node --transpile-only -r tsconfig-paths/register src/mcp/mcp-server.ts",
    "db:migrate": "ts-node -r tsconfig-paths/register src/scripts/migrate.ts",
    "db:seed": "ts-node -r tsconfig-paths/register src/scripts/seed.ts",
    "eval": "ts-node -r tsconfig-paths/register src/scripts/eval.ts",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "gray-matter": "^4.0.3",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
