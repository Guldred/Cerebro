# ─────────────────────────────────────────────────────────────────────────────
# Cerebro configuration. Copy to `.env` and adjust. NEVER commit a real `.env`.
# The defaults below make the full RAG path run locally with NO external keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── HTTP API ────────────────────────────────────────────────────────────────
PORT=3000

# ── PostgreSQL + pgvector ─────────────────────────────────────────────────────
# Matches docker-compose.yml. Point at your own EU-region Postgres in prod.
DATABASE_URL=postgres://cerebro:cerebro@localhost:5433/cerebro

# ── Embeddings ────────────────────────────────────────────────────────────────
# Provider: `fake` (default, deterministic hashing embedding — no keys, runs in CI)
#           `azure-openai` (EU region) | `openai-compatible` (e.g. self-hosted bge-m3 via TEI/Ollama)
EMBEDDING_PROVIDER=fake
# IMPORTANT: must equal the pgvector column dimension in db/migrations/001_init.sql.
# Changing this requires a migration. 1024 = bge-m3 / multilingual-e5-large.
EMBEDDING_DIM=1024

# Azure OpenAI (only used when EMBEDDING_PROVIDER=azure-openai)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# OpenAI-compatible embedding endpoint (self-hosted bge-m3 / e5 behind TEI, vLLM, Ollama)
EMBEDDING_BASE_URL=http://localhost:8080/v1
EMBEDDING_MODEL=bge-m3
EMBEDDING_API_KEY=

# ── LLM (generation) ──────────────────────────────────────────────────────────
# Provider: `fake` (default, deterministic extractive grounded answer — no keys)
#           `azure-openai` | `openai-compatible`
LLM_PROVIDER=fake
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
LLM_BASE_URL=http://localhost:8081/v1
LLM_MODEL=
LLM_API_KEY=

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=8            # final chunks handed to the LLM
RETRIEVAL_CANDIDATES=40      # candidates fetched per leg (vector + FTS) before RRF
RRF_K=60                     # Reciprocal Rank Fusion constant
FTS_CONFIG=simple            # Postgres text-search config; `simple` is safest for mixed DE+EN
HNSW_EF_SEARCH=100           # HNSW search breadth (higher = better recall, slower)
# pgvector 0.8+ iterative scan — keeps recall when the ACL filter is selective
# (HNSW post-filtering would otherwise silently return fewer than topK results).
HNSW_ITERATIVE_SCAN=true

# ── Ingestion source (npm run db:seed) ───────────────────────────────────────
# `sample` (default, reads seed/*.md) | `confluence` (Cloud REST/CQL) | `github` | `gitlab`
SEED_CONNECTOR=sample

# Only used when SEED_CONNECTOR=confluence. Token belongs in a secret manager.
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_KEYS=          # optional, comma-separated (e.g. ENG,LEGAL)

# Only used when SEED_CONNECTOR=github. PAT needs read access to the repos;
# ingests documentation files (README/*.md/...) + a synthesized repo-activity
# overview (languages, recent commits). Token belongs in a secret manager.
GITHUB_TOKEN=
GITHUB_REPOS=                   # comma-separated owner/repo (e.g. Guldred/Cerebro,Guldred/other)
GITHUB_API_URL=                 # optional, for GitHub Enterprise (default https://api.github.com)

# Only used when SEED_CONNECTOR=gitlab. PAT (read_api) optional for public
# projects. Visibility maps straight onto the ACL model: public -> public,
# internal -> all-users (any authenticated caller), private ->
# gitlab-project:<path> (granted via principal_mappings); anything else
# quarantines (fail-closed).
GITLAB_TOKEN=
GITLAB_PROJECTS=                # comma-separated full paths (e.g. group/project,group/sub/other)
GITLAB_BASE_URL=                # optional, for self-managed GitLab (default https://gitlab.com)

# ── Permissions ───────────────────────────────────────────────────────────────
# When true, retrieval is hard-filtered on acl_principals && caller principals.
ACL_ENFORCED=true
# Principal automatically granted to every caller (public content baseline).
PUBLIC_PRINCIPAL=public

# Observability: each query emits a structured JSON log (chunk ids + scores,
# per-stage latency, token usage). The raw query is HASHED by default — a query
# can be Art. 9 special-category data. Set true only to log raw query text in a
# safe debugging environment.
OBSERVABILITY_LOG_QUERY_TEXT=false

# ── Identity / AuthN (Phase 2) ────────────────────────────────────────────────
# Deployment environment. 'production' makes insecure combinations UNBOOTABLE:
# AUTH_MODE must be oidc, ACL_ENFORCED must be true, no file-based JWKS.
CEREBRO_ENV=development

# dev-header  — trust the x-cerebro-principals header (MVP stub; local DX only)
# local-oidc  — full OIDC validation against a LOCAL JWKS file. Same verifier
#               code as production, zero network — used by CI/tests and local
#               hardening work (mint a trust root: npm run auth:dev-jwks)
# oidc        — full OIDC validation against the IdP's remote JWKS (production)
AUTH_MODE=dev-header

# Entra ID app registration (required in oidc/local-oidc modes)
AUTH_OIDC_ISSUER=                # https://login.microsoftonline.com/<tenantId>/v2.0
AUTH_OIDC_AUDIENCE=              # api://<app-id-uri> or the client id
AUTH_OIDC_JWKS_URL=              # default: derived <tenant-base>/discovery/v2.0/keys
AUTH_OIDC_JWKS_FILE=             # local-oidc ONLY (production refuses a file trust root)
AUTH_CLOCK_TOLERANCE_S=60        # JWT exp/nbf skew tolerance
AUTH_GROUPS_CLAIM=groups         # Entra claim carrying transitive group object ids

# Groups OVERAGE resolver. When a user is in too many groups, Entra omits the
# `groups` claim; 'none' (default) keeps the fail-closed hard 403 for that caller,
# 'graph' resolves the full set from Microsoft Graph (getMemberGroups) with an app
# (client-credentials) token. App needs GroupMember.Read.All + User.ReadBasic.All.
AUTH_GROUP_RESOLVER=none
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_BASE_URL=https://graph.microsoft.com        # set for sovereign clouds (prod: https)
GRAPH_AUTHORITY=https://login.microsoftonline.com # token authority (prod: https)
# MUST mirror the tenant's groupMembershipClaims manifest: true = security groups
# only (the "SecurityGroup" setting); false = all groups + directory roles ("All").
# A mismatch under-serves (subset) or LEAKS principals (superset) to overage users.
GRAPH_SECURITY_ENABLED_ONLY=true
# Per-oid resolved-group cache. 0 (default) = resolve every overage request (softens
# nothing, fail-closed). Raise to reduce Graph throttling, eyes open.
AUTH_GROUP_RESOLVER_CACHE_TTL_MS=0

# Principal-mapping expansion cache. 0 (default) = no cache: deleting a
# principal_mappings row revokes on the very next query. Raising this trades
# revocation latency for load — an eyes-open decision.
PRINCIPAL_MAPPING_CACHE_TTL_MS=0

# Max chunks per embed() request. Caps the batch so one large document cannot
# exceed the embedder's per-request item/token limit (a doc's chunks would
# otherwise all go in one call). 0 disables the cap.
EMBEDDING_MAX_BATCH=96

# Confluence space keys an admin CERTIFIES as world-readable; unrestricted
# pages in any other space stay behind confluence-space:<KEY> (mapping-table
# resolved). "Non-public unless explicitly certified public."
CONFLUENCE_PUBLIC_SPACES=

# ── MCP end-user identity (oidc modes) ────────────────────────────────────────
# The end-user's bearer token, placed by the agent host, re-read + re-verified
# on EVERY tool call. chmod 600 — a group/world-readable file is refused.
# Without a resolvable identity every MCP tool call is hard-rejected (no
# service-credential fallback). Tokens never travel as tool arguments.
MCP_USER_TOKEN_FILE=
# dev-header mode only: launcher-set principals for local MCP demos.
CEREBRO_MCP_PRINCIPALS=

# ── Delegated agent access — Totem (docs/Totem_Integration.md) ─────────────────
# ALL default OFF: Cerebro boots and the eval passes with delegation + chain off.
# A delegated bearer JWT (RFC 8693: sub=human, act=agent) is verified against the
# DELEGATION_* trust root (the same jose validation as AUTH_*) and enforced as a
# strict intersection on top of the unchanged human ACL — it can only narrow.
# When ON, the delegation trust root is held to the same fail-closed boot bar as
# AUTH_MODE (prod: https issuer/JWKS, no local file). Try it: npm run auth:dev-delegation
DELEGATION_ENABLED=false
# When true, a request with no valid delegation is denied (delegation mandatory).
DELEGATION_REQUIRE=false
DELEGATION_ISSUER=               # the delegation mint / token-exchange STS issuer
DELEGATION_AUDIENCE=            # this resource (e.g. api://cerebro)
DELEGATION_JWKS_URL=            # remote JWKS (production)
DELEGATION_JWKS_FILE=          # local JWKS (dev/local/CI ONLY; production refuses it)
DELEGATION_MAX_TTL_S=300        # cap on delegated-token lifetime (short by design; max 3600)
# Audit/anchor sink: 'local' append-only (default) or the opt-in 'onchain' adapter.
# 'onchain' additionally requires DELEGATION_ONCHAIN_ACK=true (the chain is off by default).
DELEGATION_AUDIT_BACKEND=local
# Phase 2 — per-MCP-call policy decision point (independently flaggable).
DELEGATION_PDP_ENABLED=false
# Comma list of source_systems that trigger a Phase-2 late-binding membership re-check.
DELEGATION_SENSITIVE_SOURCES=
# Late-binding membership oracle: 'unverified' (default; honest unknown → step-up)
# or 'github' (re-confirms LIVE org membership at call time, closing the chunk-ACL
# window). The github checker bridges the caller to a GitHub login via the
# identity_links table and reads membership live — it NEVER widens the ACL set.
DELEGATION_MEMBERSHIP_CHECKER=unverified
# Required when DELEGATION_MEMBERSHIP_CHECKER=github: the org whose membership
# gates the sensitive `github` source.
DELEGATION_GITHUB_MEMBERSHIP_ORG=
# A read token that is ITSELF a member of the org (so the members API returns an
# unambiguous 204/404 instead of a 302 to the public-member list). Mandatory in
# production; dev/local may run keyless (every check then steps up).
DELEGATION_GITHUB_MEMBERSHIP_TOKEN=
# API base — default api.github.com; set for GitHub Enterprise Server.
DELEGATION_GITHUB_API_URL=

# ── GDPR erasure (docs/Erasure_Runbook.md) ────────────────────────────────────
# Deployment-wide pepper for the erasure-receipt digest (sha256(pepper ‖ target)):
# keeps erasure_log non-identifying while staying verify-on-demand. Set a secret
# in production; empty in dev makes the digest an unsalted hash (the script warns).
ERASURE_PEPPER=
